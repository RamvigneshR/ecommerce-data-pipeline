# Database Connectivity
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USER=your_postgres_username
DB_PASSWORD=your_password

# Storage path for raw data file
STORAGE_PATH=

LOG_PATH=

API_URL=https://api.escuelajs.co/api/v1

PROCESS_DATE=YYYY-MM-DD
